### Change 2: Improved scanNodes() method

```diff
     private fun scanNodes(view: DimPunchOutView) {
         scanJob?.cancel()
         scanJob = scope.launch {
+            val root = getRoot()
+            android.util.Log.d("CopyText", "scanNodes: Root node = $root, package = ${root?.packageName}")
+            
+            if (root == null) {
+                android.util.Log.w("CopyText", "ERROR: getRoot() returned null! Cannot scan text nodes.")
+                detectedNodes.clear()
+                view.invalidate()
+                return@launch
+            }
+            
             val nodes = withContext(Dispatchers.Default) {
-                collectTextNodes(getRoot())
+                collectTextNodes(root)
             }
+            android.util.Log.d("CopyText", "Collected ${nodes.size} text nodes from accessibility tree")
             detectedNodes.clear()
             detectedNodes.addAll(nodes)
             view.invalidate() 
         }
     }
```

