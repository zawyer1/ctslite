<!--
    FORK CHANGES vs original manifest:

    PERMISSIONS REMOVED:
      - android.permission.BIND_ACCESSIBILITY_SERVICE  (no longer used)
      - android.permission.FOREGROUND_SERVICE          (only needed by AccessibilityService overlay)
      - android.permission.WRITE_EXTERNAL_STORAGE      (only needed by AccessibilityService features)
      - android.permission.MANAGE_EXTERNAL_STORAGE     (only needed by AccessibilityService features)
      - android.permission.QUERY_ALL_PACKAGES          (only needed for OPEN_APP action in AccessibilityService)

    SERVICES / ACTIVITIES REMOVED:
      - CircleToSearchAccessibilityService  (deleted — was the accessibility overlay service)
      - CircleToSearchRecognitionService    (deleted — was a stub required by assist_service_config)
      - CircleToSearchTileService           (deleted — was the Quick Settings tile)
      - TileTriggerActivity                 (deleted — was the Quick Settings tile launcher)

    RETAINED:
      - MainActivity
      - CircleToSearchVoiceService          (registers app as an assistant in Android settings)
      - AssistSessionService                (handles screenshot delivery via onHandleScreenshot)
      - OverlayActivity                     (the crop/draw/search UI — core functionality)
      - FileProvider                        (for sharing cropped images to search engines)
      - INTERNET, VIBRATE permissions
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CircleToSearch"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CircleToSearch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            VoiceInteractionService: makes the app appear in Android's
            "Default assistant" settings. No screenshot or accessibility
            permissions required.
        -->
        <service
            android:name=".CircleToSearchVoiceService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/assist_service_config" />
        </service>

        <!--
            VoiceInteractionSessionService: receives the screenshot bitmap via
            onHandleScreenshot() when the assistant is invoked (long-press home /
            edge-swipe up). This is the sole capture mechanism in this fork.
        -->
        <service
            android:name=".AssistSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true" />
        <service
            android:name=".StubRecognitionService"
            android:exported="true"
            android:permission="android.permission.BIND_RECOGNITION_SERVICE">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!--
            OverlayActivity: the transparent full-screen crop/draw/search UI.
            Launched by AssistSessionService after the screenshot is stored
            in BitmapRepository.
        -->
        <activity
            android:name=".OverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.CircleToSearch.Transparent"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>